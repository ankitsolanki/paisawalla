# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database Configuration
# MongoDB connection string
# Example: mongodb://localhost:27017/paisawalla
# Or: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/pw_db

# reCAPTCHA Configuration
# Get your keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=6LcdQAcsAAAAAE-i6GyfBIYyTQYVh1APMqtQ1e5H
RECAPTCHA_SITE_KEY=6LcdQAcsAAAAAAMYlfXPbaWav5GIh7oWY5MtUhW2

# CORS Configuration
# For production, set this to your frontend domain(s)
# Single origin: CORS_ORIGIN=https://app-paisawalla.gofo.app
# Multiple origins (comma-separated): CORS_ORIGIN=https://app1.com,https://app2.com
# For development, leave empty to allow all localhost origins
CORS_ORIGIN=https://app-paisawalla.gofo.app

# BRE (Business Rules Engine) API Configuration
BRE_API_URL=
BRE_API_KEY=

# Bureau API Configuration
BUREAU_API_URL=
BUREAU_API_KEY=

# Rate Limiting Configuration (Optional)
# Rate limit window in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100
