# =========================
# Backend Environment Variables
# =========================

# App Configuration
PORT=3000
SESSION_SECRET=your_session_secret_here

# Database
MONGODB_URI=mongodb://localhost:27017/your_database_name

# =========================
# Experian Configuration
# =========================

EXPERIAN_CLIENT_ID=your_experian_client_id
EXPERIAN_CLIENT_SECRET=your_experian_client_secret
EXPERIAN_USERNAME=your_experian_username
EXPERIAN_PASSWORD=your_experian_password
EXPERIAN_CLIENT_NAME=your_experian_client_name
EXPERIAN_VOUCHER_CODE=your_experian_voucher_code

# Experian BRE (Business Rules Engine)
EXPERIAN_BRE_CLIENT_ID=your_experian_bre_client_id
EXPERIAN_BRE_CLIENT_SECRET=your_experian_bre_client_secret
EXPERIAN_BRE_USERNAME=your_experian_bre_username
EXPERIAN_BRE_PASSWORD=your_experian_bre_password

# =========================
# Karix Configuration
# =========================

KARIX_ACCESS_KEY=your_karix_access_key
KARIX_IP_ADDRESS=your_karix_ip_address


# frontend host
VITE_EMBED_BASE=http://localhost:5173