{
  "formId": "form1",
  "title": "Personal Loan Application",
  "submitEndpoint": "/api/leads",
  "steps": 6,
  "fields": [
    {
      "name": "phone",
      "label": "Mobile Number",
      "type": "tel",
      "placeholder": "10-digit mobile number",
      "required": true,
      "validation": {
        "regex": "^[6-9][0-9]{9}$",
        "minLength": 10,
        "maxLength": 10
      },
      "step": 1
    },
    {
      "name": "otp",
      "label": "Enter Verification Code",
      "type": "otp",
      "placeholder": "Enter the 6-digit code sent to your mobile",
      "required": true,
      "validation": {
        "regex": "^[0-9]{6}$",
        "minLength": 6,
        "maxLength": 6
      },
      "step": 1
    },
    {
      "name": "consentCreditCheck",
      "label": "I authorize PW.com to access my credit information",
      "type": "checkbox",
      "required": true,
      "step": 1
    },
    {
      "name": "consentMarketing",
      "label": "I consent to receive marketing communications",
      "type": "checkbox",
      "required": false,
      "step": 1
    },
    {
      "name": "firstName",
      "label": "First Name",
      "type": "text",
      "placeholder": "Enter your first name",
      "required": true,
      "validation": {
        "minLength": 2,
        "maxLength": 50
      },
      "step": 2
    },
    {
      "name": "lastName",
      "label": "Last Name",
      "type": "text",
      "placeholder": "Enter your last name",
      "required": true,
      "validation": {
        "minLength": 2,
        "maxLength": 50
      },
      "step": 2
    },
    {
      "name": "email",
      "label": "Email Address",
      "type": "email",
      "placeholder": "you@example.com",
      "required": true,
      "validation": {
        "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
      },
      "step": 2
    },
    {
      "name": "dateOfBirth",
      "label": "Date of Birth",
      "type": "date",
      "required": true,
      "step": 2
    },
    {
      "name": "ssn",
      "label": "PAN Number",
      "type": "text",
      "placeholder": "ABCDE1234F",
      "required": true,
      "validation": {
        "regex": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
        "minLength": 10,
        "maxLength": 10
      },
      "step": 2
    },
    {
      "name": "address",
      "label": "Street Address",
      "type": "text",
      "placeholder": "Enter your street address",
      "required": true,
      "validation": {
        "minLength": 5
      },
      "step": 2,
      "fullWidth": true
    },
    {
      "name": "city",
      "label": "City",
      "type": "text",
      "placeholder": "Enter your city",
      "required": true,
      "validation": {
        "minLength": 2
      },
      "step": 2
    },
    {
      "name": "state",
      "label": "State",
      "type": "select",
      "required": true,
      "options": [
        { "value": "Maharashtra", "label": "Maharashtra" },
        { "value": "Delhi", "label": "Delhi" },
        { "value": "Karnataka", "label": "Karnataka" },
        { "value": "Tamil Nadu", "label": "Tamil Nadu" },
        { "value": "Gujarat", "label": "Gujarat" },
        { "value": "West Bengal", "label": "West Bengal" },
        { "value": "Rajasthan", "label": "Rajasthan" },
        { "value": "Uttar Pradesh", "label": "Uttar Pradesh" },
        { "value": "Punjab", "label": "Punjab" },
        { "value": "Haryana", "label": "Haryana" },
        { "value": "Other", "label": "Other" }
      ],
      "step": 2
    },
    {
      "name": "zipCode",
      "label": "ZIP Code",
      "type": "text",
      "placeholder": "Enter ZIP code",
      "required": true,
      "validation": {
        "regex": "^[0-9]{6}$",
        "minLength": 6,
        "maxLength": 6
      },
      "step": 2
    },
    {
      "name": "yearsAtAddress",
      "label": "Years at Current Address",
      "type": "number",
      "placeholder": "e.g. 2",
      "required": true,
      "validation": {
        "min": 0,
        "max": 50
      },
      "step": 2
    },
    {
      "name": "employmentStatus",
      "label": "Employment Type",
      "type": "select",
      "required": true,
      "options": [
        { "value": "salaried", "label": "Salaried" },
        { "value": "self-employed", "label": "Self-Employed" },
        { "value": "business", "label": "Business Owner" },
        { "value": "retired", "label": "Retired" },
        { "value": "student", "label": "Student" }
      ],
      "step": 3
    },
    {
      "name": "employerName",
      "label": "Employer/Company Name",
      "type": "text",
      "placeholder": "Enter employer name",
      "required": true,
      "validation": {
        "minLength": 2
      },
      "step": 3
    },
    {
      "name": "jobTitle",
      "label": "Job Title",
      "type": "text",
      "placeholder": "Enter your job title",
      "required": true,
      "validation": {
        "minLength": 2
      },
      "step": 3
    },
    {
      "name": "monthlyIncome",
      "label": "Monthly Income (INR)",
      "type": "number",
      "placeholder": "e.g. 50000",
      "required": true,
      "validation": {
        "min": 10000,
        "max": 10000000
      },
      "step": 3
    },
    {
      "name": "yearsEmployed",
      "label": "Years at Current Job",
      "type": "number",
      "placeholder": "e.g. 3",
      "required": true,
      "validation": {
        "min": 0,
        "max": 50
      },
      "step": 3
    },
    {
      "name": "loanAmount",
      "label": "Desired Loan Amount (INR)",
      "type": "number",
      "placeholder": "e.g. 500000",
      "required": true,
      "validation": {
        "min": 10000,
        "max": 50000000
      },
      "step": 4
    },
    {
      "name": "loanPurpose",
      "label": "Loan Purpose",
      "type": "select",
      "required": true,
      "options": [
        { "value": "debt_consolidation", "label": "Debt Consolidation" },
        { "value": "home_improvement", "label": "Home Improvement" },
        { "value": "medical_expenses", "label": "Medical Expenses" },
        { "value": "education", "label": "Education" },
        { "value": "wedding", "label": "Wedding" },
        { "value": "vacation", "label": "Vacation" },
        { "value": "other", "label": "Other" }
      ],
      "step": 4
    },
    {
      "name": "creditScore",
      "label": "Credit Score (if known)",
      "type": "number",
      "placeholder": "e.g. 750",
      "required": false,
      "validation": {
        "min": 300,
        "max": 850
      },
      "step": 4
    },
    {
      "name": "bankAccountNumber",
      "label": "Bank Account Number",
      "type": "text",
      "placeholder": "Enter account number",
      "required": true,
      "validation": {
        "minLength": 9,
        "maxLength": 18
      },
      "step": 4
    },
    {
      "name": "routingNumber",
      "label": "IFSC Code",
      "type": "text",
      "placeholder": "e.g. HDFC0001234",
      "required": true,
      "validation": {
        "regex": "^[A-Z]{4}0[A-Z0-9]{6}$",
        "minLength": 11,
        "maxLength": 11
      },
      "step": 4
    },
    {
      "name": "hasCoSigner",
      "label": "Do you have a co-signer?",
      "type": "select",
      "required": true,
      "options": [
        { "value": "yes", "label": "Yes" },
        { "value": "no", "label": "No" }
      ],
      "step": 6
    },
    {
      "name": "previousLoans",
      "label": "Have you had previous loans?",
      "type": "select",
      "required": true,
      "options": [
        { "value": "yes", "label": "Yes" },
        { "value": "no", "label": "No" }
      ],
      "step": 6
    }
  ]
}

