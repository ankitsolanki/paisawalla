{
  "formId": "form2",
  "title": "Check Your Loan Eligibility",
  "description": "Find out your eligibility in under 2 minutes. No impact on your credit score.",
  "submitEndpoint": "/api/leads",
  "steps": 2,
  "fields": [
    {
      "name": "fullName",
      "label": "Full Name",
      "type": "text",
      "placeholder": "Enter your full name as per PAN card",
      "required": true,
      "rules": ["required", "firstName"],
      "errorMessage": "Please enter a valid full name",
      "maxLength": 26,
      "step": 1
    },
    {
      "name": "email",
      "label": "Email",
      "type": "email",
      "placeholder": "you@example.com",
      "required": true,
      "rules": ["required", "email"],
      "errorMessage": "Please enter a valid Email",
      "step": 1
    },
    {
      "name": "dateOfBirth",
      "label": "Date of Birth (DOB)",
      "type": "date",
      "placeholder": "Select your date of birth (dd-mm-yyyy)",
      "required": true,
      "rules": ["required", "dobDate"],
      "errorMessage": "Please enter a valid Date of Birth",
      "step": 1
    },
    {
      "name": "pinCode",
      "label": "Pin code",
      "type": "pincode",
      "placeholder": "Enter 6-digit PIN code",
      "required": true,
      "rules": ["required", "zipCode"],
      "errorMessage": "Please select a pin code",
      "maxLength": 6,
      "searchType": true,
      "cityFieldName": "city",
      "stateFieldName": "state",
      "step": 1
    },
    {
      "name": "panNumber",
      "label": "PAN Number",
      "type": "text",
      "placeholder": "Enter PAN number (e.g., ABCDE1234F)",
      "required": true,
      "rules": ["required", "pan"],
      "errorMessage": "Please Enter a Valid Pan",
      "maxLength": 10,
      "step": 1
    },
    {
      "name": "loanAmount",
      "label": "Desired Loan Amount",
      "type": "currency",
      "placeholder": "Enter desired loan amount",
      "required": true,
      "rules": ["required", "numeric", { "type": "min", "params": [10000] }, { "type": "max", "params": [100000000] }],
      "errorMessage": "Please provide a desired loan amount",
      "min": 10000,
      "max": 100000000,
      "step": 2
    },
    {
      "name": "employmentType",
      "label": "Employment Type",
      "type": "select",
      "placeholder": "Select employment type",
      "required": true,
      "rules": ["required"],
      "errorMessage": "Please enter a valid Employment type",
      "options": [
        { "value": "Salaried", "label": "Salaried" },
        { "value": "Self-employed professional", "label": "Self-employed professional" },
        { "value": "Self-employed business", "label": "Self-employed business" },
        { "value": "Student", "label": "Student" }
      ],
      "step": 2
    },
    {
      "name": "netMonthlyIncome",
      "label": "Net Monthly Income",
      "type": "currency",
      "placeholder": "Enter monthly income",
      "required": true,
      "rules": ["required", "numeric", { "type": "min", "params": [10000] }, { "type": "max", "params": [10000000] }],
      "errorMessage": "This field is required(not more than 8 numeric digit)",
      "min": 10000,
      "max": 10000000,
      "step": 2
    },
    {
      "name": "companyName",
      "label": "Company Name",
      "type": "text",
      "placeholder": "Enter your company name",
      "required": true,
      "rules": ["required"],
      "errorMessage": "Please enter a valid company name",
      "step": 2
    },
    {
      "name": "modeOfSalary",
      "label": "Mode of Salary",
      "type": "select",
      "placeholder": "Select mode of salary",
      "required": true,
      "rules": ["required"],
      "errorMessage": "Please select a mode of salary",
      "options": [
        { "value": "bank_account", "label": "Bank Account" },
        { "value": "cash", "label": "Cash" },
        { "value": "cheque", "label": "Cheque" }
      ],
      "step": 2
    },
    {
      "name": "city",
      "label": "City",
      "type": "text",
      "placeholder": "Select or enter city",
      "required": true,
      "rules": ["required", "city"],
      "errorMessage": "Please select a city",
      "searchType": true,
      "step": 1
    },
    {
      "name": "state",
      "label": "State",
      "type": "select",
      "placeholder": "Select state",
      "required": true,
      "rules": ["required"],
      "errorMessage": "Please select a state",
      "searchType": true,
      "options": [
        { "value": "1", "label": "Andhra Pradesh" },
        { "value": "2", "label": "Arunachal Pradesh" },
        { "value": "3", "label": "Assam" },
        { "value": "4", "label": "Bihar" },
        { "value": "5", "label": "Chhattisgarh" },
        { "value": "6", "label": "Delhi" },
        { "value": "7", "label": "Goa" },
        { "value": "8", "label": "Gujarat" },
        { "value": "9", "label": "Haryana" },
        { "value": "10", "label": "Himachal Pradesh" },
        { "value": "11", "label": "Jharkhand" },
        { "value": "12", "label": "Karnataka" },
        { "value": "13", "label": "Kerala" },
        { "value": "14", "label": "Madhya Pradesh" },
        { "value": "15", "label": "Maharashtra" },
        { "value": "16", "label": "Manipur" },
        { "value": "17", "label": "Meghalaya" },
        { "value": "18", "label": "Mizoram" },
        { "value": "19", "label": "Nagaland" },
        { "value": "20", "label": "Odisha" },
        { "value": "21", "label": "Punjab" },
        { "value": "22", "label": "Rajasthan" },
        { "value": "23", "label": "Sikkim" },
        { "value": "24", "label": "Tamil Nadu" },
        { "value": "25", "label": "Telangana" },
        { "value": "26", "label": "Tripura" },
        { "value": "27", "label": "Uttar Pradesh" },
        { "value": "28", "label": "Uttarakhand" },
        { "value": "29", "label": "West Bengal" },
        { "value": "30", "label": "Puducherry" }
      ],
      "step": 1
    }
  ]
}
