# =============================================================================
# PaisaWaala Backend — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] have defaults shown after the = sign.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database (MongoDB) [REQUIRED]
# -----------------------------------------------------------------------------
# Your MongoDB replica set connection string
# Format: mongodb://username:password@host1:port,host2:port,host3:port/?replicaSet=rs0&authSource=admin
MONGODB_URI=mongodb://admin:sPd8kLm1xQ@mongo1.digihealth.in:28000,mongo2.digihealth.in:28001,mongo3.digihealth.in:28002/?replicaSet=rs0&authSource=admin
MONGODB_RETRY_ATTEMPTS=5
MONGODB_RETRY_DELAY=5000

# -----------------------------------------------------------------------------
# CORS [REQUIRED for production]
# -----------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins (no trailing slashes, no spaces)
# Include your Amplify URL, custom domain, and any Webflow sites using embeds
CORS_ORIGIN=https://app.paisawaala.com,https://paisawaala.webflow.io,https://app-paisawalla.gofo.app

# -----------------------------------------------------------------------------
# Karix OTP [REQUIRED for OTP functionality]
# -----------------------------------------------------------------------------
# Get these from your Karix dashboard
KARIX_ACCESS_KEY=your-karix-access-key
KARIX_BASE_URL=https://auth.instaalerts.zone/otpauthapi
KARIX_DEPARTMENT_ID=Uni_SMS_OTP_feb20
# Set this to your EC2 server's public IP address
KARIX_IP_ADDRESS=your-ec2-public-ip

# -----------------------------------------------------------------------------
# Google reCAPTCHA v3 [OPTIONAL]
# -----------------------------------------------------------------------------
# Get keys from: https://www.google.com/recaptcha/admin
# If not set, reCAPTCHA validation is skipped
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# -----------------------------------------------------------------------------
# Rate Limiting [OPTIONAL — defaults shown]
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
FORM_SUBMISSION_WINDOW_MS=900000
FORM_SUBMISSION_MAX_REQUESTS=10

# -----------------------------------------------------------------------------
# Lender Eligibility [OPTIONAL]
# -----------------------------------------------------------------------------
# Decision mode: ECV (credit check based) or BRE (business rules engine)
DECISION_MODE=ECV

# -----------------------------------------------------------------------------
# Experian ECV (Enhanced Credit View) [OPTIONAL — needed for credit checks]
# -----------------------------------------------------------------------------
# Auth: POST https://uat-in-api.experian.com/oauth2/v1/token (x-www-form-urlencoded)
# For production, change base URL to: https://in-api.experian.com
EXPERIAN_BASE_URL=https://uat-in-api.experian.com
EXPERIAN_CLIENT_ID=
EXPERIAN_CLIENT_SECRET=
EXPERIAN_USERNAME=
EXPERIAN_PASSWORD=
EXPERIAN_USER_DOMAIN=theunimobile.com
EXPERIAN_CLIENT_NAME=
EXPERIAN_VOUCHER_CODE=

# -----------------------------------------------------------------------------
# Experian BRE (Business Rules Engine) [OPTIONAL — needed for BRE decisions]
# -----------------------------------------------------------------------------
# Auth: POST https://in-api.experian.com/auth/experianone/v1/token (JSON body)
# NOTE: BRE uses SEPARATE credentials from ECV. Do not reuse ECV values.
# NOTE: BRE production API requires your EC2 IP to be whitelisted by Experian.
EXPERIAN_BRE_BASE_URL=https://in-api.experian.com
EXPERIAN_BRE_PATH=/decisionanalytics/experianone/nps6t36gvswc/services
EXPERIAN_BRE_CLIENT_ID=
EXPERIAN_BRE_CLIENT_SECRET=
EXPERIAN_BRE_USERNAME=
EXPERIAN_BRE_PASSWORD=
