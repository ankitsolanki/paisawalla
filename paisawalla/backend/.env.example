# =============================================================================
# Paisawalla Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] have sensible defaults shown after the = sign.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database (MongoDB) [REQUIRED]
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/?replicaSet=rs0&authSource=admin
MONGODB_RETRY_ATTEMPTS=5
MONGODB_RETRY_DELAY=5000

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGIN=https://paisawaala.webflow.io,https://app-paisawalla.gofo.app

# -----------------------------------------------------------------------------
# Google reCAPTCHA v3 [OPTIONAL]
# Get your keys from: https://www.google.com/recaptcha/admin
# -----------------------------------------------------------------------------
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# -----------------------------------------------------------------------------
# Rate Limiting [OPTIONAL]
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
FORM_SUBMISSION_WINDOW_MS=900000
FORM_SUBMISSION_MAX_REQUESTS=10

# -----------------------------------------------------------------------------
# Lender Eligibility
# -----------------------------------------------------------------------------
# Decision mode for lender rule engine: ECV or BRE
DECISION_MODE=ECV

# -----------------------------------------------------------------------------
# Experian ECV (Enhanced Credit View) [OPTIONAL - needed for credit checks]
# Auth endpoint: https://uat-in-api.experian.com/oauth2/v1/token
# Body format: x-www-form-urlencoded
# -----------------------------------------------------------------------------
EXPERIAN_BASE_URL=https://uat-in-api.experian.com
EXPERIAN_CLIENT_ID=
EXPERIAN_CLIENT_SECRET=
EXPERIAN_USERNAME=
EXPERIAN_PASSWORD=
EXPERIAN_USER_DOMAIN=theunimobile.com
EXPERIAN_CLIENT_NAME=
EXPERIAN_VOUCHER_CODE=

# -----------------------------------------------------------------------------
# Experian BRE (Business Rules Engine) [OPTIONAL - needed for BRE decisions]
# Auth endpoint: https://in-api.experian.com/auth/experianone/v1/token
# Body format: JSON
# NOTE: BRE uses SEPARATE credentials from ECV. Do not reuse ECV values here.
# NOTE: BRE production API requires your server IP to be whitelisted by Experian.
# -----------------------------------------------------------------------------
EXPERIAN_BRE_BASE_URL=https://in-api.experian.com
EXPERIAN_BRE_PATH=/decisionanalytics/experianone/nps6t36gvswc/services
EXPERIAN_BRE_CLIENT_ID=
EXPERIAN_BRE_CLIENT_SECRET=
EXPERIAN_BRE_USERNAME=
EXPERIAN_BRE_PASSWORD=
